APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/drama_finder
REDIS_URL=redis://localhost:6379/0
DATA_ROOT=./data
MANIFEST_ROOT=./manifests
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_SCENE_MODEL=gemini-3-flash-preview
EMBEDDING_DIMENSION=3072
ASR_BACKEND=node
ASR_MODEL_NAME=iic/SenseVoiceSmall
ASR_MODEL_DIR=/home/james/.cache/models/SenseVoiceSmall-onnx
ASR_VAD_MODEL_NAME=funasr/fsmn-vad-onnx
ASR_VAD_MODEL_DIR=/home/james/.cache/models/fsmn-vad-compat
ASR_DEVICE=cpu
ASR_CPU_CORES=2
ASR_COMPUTE_TYPE=int8
ASR_STREAM_CHUNK_SECONDS=30
ASR_VAD_MERGE_GAP_MS=300
ASR_SEGMENT_MAX_SECONDS=30
ASR_ENABLE_PUNCTUATION=true
ASR_NODE_PROJECT_DIR=/home/james/works/tooling/coli
ASR_NODE_CLI_PATH=scripts/node_stream_asr.mjs
ASR_NODE_MODEL_DIR=/home/james/.coli/models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
ASR_NODE_VAD_MODEL_PATH=/home/james/.coli/models/silero_vad.onnx
ASR_NODE_PUNC_MODEL_PATH=/home/james/.coli/models/sherpa-onnx-punct-ct-transformer-zh-en-vocab272727-2024-04-12-int8/model.int8.onnx
INGEST_SKIP_EMBEDDINGS=false

# ASR punctuation model:
# https://github.com/k2-fsa/sherpa-onnx/releases/tag/punctuation-models
